# LLM Configuration (Required)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_ID=gpt-3.5-turbo
LLM_TIMEOUT=60

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Paths (relative to Agent-Hemo project root)
MEMORY_DIR=./data/memory
SKILLS_DIR=./data/skills
KNOWLEDGE_DIR=./knowledge
PPTX_DIR=./data/sources/pptx
RAG_INDEX_DIR=./data/rag_index
REPORTS_DIR=./data/reports

# Agent behavior
MAX_TURNS=30
MAX_RETRIES=2
COMPACT_EVERY=5
COMPACT_RECENT_MESSAGES=4

# RAG
RAG_TOP_K=3
HF_ENDPOINT=https://hf-mirror.com
# 中文效果更好: paraphrase-multilingual-MiniLM-L12-v2
# 内存/页面文件不足时用: all-MiniLM-L6-v2
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Tools
COMMAND_TIMEOUT=30

# Alert pipeline
ALERT_CSV_PATH=data/bag_info.csv
ALERT_WARNING_DAYS=30
# WEBHOOK_URL=
# WEBHOOK_SECRET=

# ── JWT 鉴权（可选，不填则跳过鉴权） ──
# 生成密钥: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_USERNAME=admin
AUTH_PASSWORD=
# ── 限流 ──
RATE_LIMIT_DEFAULT=30/minute
RATE_LIMIT_CHAT=10/minute